# ── Closium OS — Variables d'environnement ──────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs

# Notion
NOTION_TOKEN=secret_xxx

# Google (Service Account JSON path)
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google_service_account.json

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL_GABRIEL=C0XXXXXXXXX

# Stripe (webhook signing secret — depuis Stripe Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Tally (form ID par défaut)
TALLY_FORM_ID=jaWeWJ

# Make API (compte Gabriel)
MAKE_API_KEY=xxx
MAKE_TEAM_ID=258363
MAKE_ZONE=eu2

# Webhook server
WEBHOOK_PORT=18790
WEBHOOK_SECRET=un-secret-random-fort

# OpenClaw
OPENCLAW_API_KEY=xxx
